# Ontos — copy to .env, paste your license + LLM key, then run ./install.sh
# (POSTGRES_PASSWORD and DATADEX_SECRETS_KEY are auto-generated if left blank.)

POSTGRES_PASSWORD=
DATADEX_SECRETS_KEY=
DATADEX_PORT=8080
DATADEX_AGENT_MAX_RUNS=4

# License key from Ontos Research (required — the control plane won't start without it).
ONTOS_LICENSE=

# LLM (required for the agent features) — OpenAI or Groq key.
DATADEX_SEED_LLM_PROVIDER=openai
DATADEX_SEED_LLM_API_KEY=
DATADEX_SEED_LLM_MODEL=gpt-5.4-mini
# If this host can't reach the public API, point one of these at an in-network
# / in-region OpenAI-compatible endpoint.
DATADEX_OPENAI_RESPONSES_URL=
DATADEX_GROQ_URL=

# --- Corporate proxy (optional) --------------------------------------------
# If this host reaches the internet only through a proxy, set these. The control
# plane's LLM calls route through it; loopback + internal services stay direct.
# HTTP_PROXY=http://proxy.corp.example:3128
# HTTPS_PROXY=http://proxy.corp.example:3128
# NO_PROXY=.corp.example,10.0.0.0/8   # extra internal domains/CIDRs to bypass
# If the proxy does TLS interception (re-signs HTTPS with a private root CA),
# also point this at a host CA bundle that INCLUDES that root CA — install.sh
# mounts it into the control plane so its TLS trust accepts the intercepted certs.
# ONTOS_CA_BUNDLE=/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem   # RHEL
# ONTOS_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt                  # Debian/Ubuntu
# Last resort: if the proxy's CA is non-compliant (e.g. missing Authority Key
# Identifier) and can't be fixed, skip LLM-egress cert verification. Acceptable
# only because the proxy already terminates the TLS.
# ONTOS_TLS_SKIP_VERIFY=1

# Image registry + version (pre-filled — leave as-is unless told otherwise).
ONTOS_REGISTRY=ghcr.io/ontos-research/
ONTOS_VERSION=0.1.8
